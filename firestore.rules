rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Global Helpers
    function isSignedIn() { return request.auth != null; }
    function isVerified() { return isSignedIn() && request.auth.token.email_verified == true; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    // Entity Validations
    function isValidProduct(data) {
      return data.keys().hasAll(['name', 'price', 'category', 'isAvailable']) &&
             data.keys().size() <= 6 &&
             data.name is string && data.name.size() <= 100 &&
             data.price is number && data.price >= 0 &&
             data.category is string && data.category.size() <= 50 &&
             data.isAvailable is bool &&
             (!data.keys().hasAny(['imageUrl']) || (data.imageUrl is string && data.imageUrl.size() <= 500)) &&
             (!data.keys().hasAny(['description']) || (data.description is string && data.description.size() <= 500));
    }

    function isValidOrder(data) {
      return data.keys().hasAll(['userId', 'items', 'totalAmount', 'status', 'deliveryAddress', 'phone', 'createdAt', 'updatedAt']) &&
             data.keys().size() <= 10 &&
             data.userId == request.auth.uid &&
             data.items is list && data.items.size() > 0 &&
             data.totalAmount is number && data.totalAmount >= 0 &&
             data.status in ['pending', 'preparing', 'out-for-delivery', 'delivered', 'cancelled'] &&
             data.deliveryAddress is string && data.deliveryAddress.size() <= 500 &&
             data.phone is string && data.phone.size() <= 20 &&
             (!data.keys().hasAny(['paymentStatus']) || data.paymentStatus in ['pending', 'success', 'failed']) &&
             (!data.keys().hasAny(['transactionId']) || (data.transactionId is string && data.transactionId.size() <= 128)) &&
             data.createdAt == request.time &&
             data.updatedAt == request.time;
    }

    function isValidUserProfile(data) {
      return data.keys().hasAll(['email']) &&
             data.email is string && data.email.size() <= 100 &&
             (!data.keys().hasAny(['fullName']) || (data.fullName is string && data.fullName.size() <= 100)) &&
             (!data.keys().hasAny(['phone']) || (data.phone is string && data.phone.size() <= 20)) &&
             (!data.keys().hasAny(['address']) || (data.address is string && data.address.size() <= 500)) &&
             (!data.keys().hasAny(['isAdmin']) || (data.isAdmin is bool));
    }

    // Role-based helpers (lookup)
    function isAdmin() {
      return isSignedIn() && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)/profile/private).data.isAdmin == true;
    }

    // Collections
    match /products/{productId} {
      allow read: if true; // Menu is public
      allow write: if isAdmin(); // Only admins can edit menu
    }

    match /orders/{orderId} {
      allow get: if isOwner(resource.data.userId) || isAdmin();
      allow list: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isVerified() && isValidOrder(incoming()) && isValidId(orderId);
      allow update: if isVerified() && (
        (isOwner(existing().userId) && incoming().diff(existing()).affectedKeys().hasOnly(['status']) && incoming().status == 'cancelled' && existing().status == 'pending') ||
        (isAdmin() && isValidOrder(incoming()) && incoming().userId == existing().userId)
      );
      allow delete: if false; // Orders are immutable once placed, or only status changes
    }

    match /users/{userId}/profile/private {
      allow get, write: if isOwner(userId) && isValidUserProfile(incoming());
      // Special rule: only admins can set isAdmin to true
      // This is implicit since isAdmin() check itself would be false initially
      // Users can't escalate their own privileges
      allow update: if isOwner(userId) && isValidUserProfile(incoming()) && 
                    (incoming().isAdmin == existing().isAdmin || isAdmin());
    }
  }
}
